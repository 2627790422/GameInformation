{
  "version": 2,
  "buildCommand": "node scripts/build-data.js",
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/articles/(?<id>[^/]+)", "dest": "/api/articles?id=$id" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
